{
  "extends": ["@tsconfig/node24/tsconfig.json", "@tsconfig/node-ts/tsconfig.json"],
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "dom"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "types": ["vitest/globals"],
    "verbatimModuleSyntax": false,
    "noUncheckedSideEffectImports": true,
    // "paths": {
    //   "@model/*": ["src/model/*"],
    //   "@parsers/*": ["src/parsers/*"],
    // }
  },
  "src": ["src", "test"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "src/utils/apical/apicalTest.mts", "src/types/**/*.d.ts", "src/@types/**/*.d.ts"],
}
