prefix_rule(
  pattern = [ "Get-Childitem" ]
  decision = "allow",
  justification = "Allow reading filesystem structure."
)

prefix_rule(
  pattern = [ "Get-Content" ]
  decision = "allow",
  justification = "Allow reading file contents."
)

prefix_rule(
  pattern = [ "rg" ]
  decision = "allow",
  justification = "Allow interrogation of files."
)

prefix_rule(
  pattern = [ "npm", "run", "test" ]
  decision = "allow",
  justification = "Allow running tests."
)

prefix_rule(
  pattern = [ "npm", "test" ]
  decision = "allow",
  justification = "Allow running tests."
)
