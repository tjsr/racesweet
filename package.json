{
  "name": "racesweet",
  "version": "0.0.1",
  "description": "Race entry and results utilities",
  "keywords": [
    "Racing",
    "Timing",
    "Results"
  ],
  "license": "ISC",
  "author": "Tim Rowe <tim@tjsr.id.au>",
  "type": "commonjs",
  "main": ".webpack/main",
  "old.main": "index.mjs",
  "vite.main": ".vite/build/main.js",
  "scripts": {
    "build": "npm run types && npm run compile && npm run test && npm run lint",
    "compile": "tsc && npm run compile:electron && babel index.mjs -d build",
    "compile:electron": "electron-forge package",
    "clean": "rimraf src/generated build dist .webpack .vite out",
    "clean:all": "npm cache clean --force && npm run clean && npx rimraf node_modules",
    "generate:handicaps": "tsx ./src/utils/apical/apicalTest.mts",
    "generate:handicaps:force-refresh": "tsx ./src/utils/apical/apicalTest.mts --force-refresh",
    "generate:handicaps:refresh-events": "tsx ./src/utils/apical/apicalTest.mts --refresh-events",
    "generate:handicaps:refresh-excel": "tsx ./src/utils/apical/apicalTest.mts --refresh-excel",
    "lint": "npm run lint:ts && npm run lint:json",
    "lint:json": "node ./scripts/lintJson.mjs src",
    "lint:ts": "eslint",
    "kill-port": "tsx ./src/app/killPort.ts",
    "serve": "tsx ./src/app/startElectronForge.ts",
    "start": "tsx ./src/app/startElectronForge.ts --trace-warnings",
    "start:no-trace": "tsx ./src/app/startElectronForge.ts",
    "test": "rimraf node_modules/.vite .vitest && vitest run",
    "test:integration:all": "node ./scripts/runIntegrationTests.mjs",
    "test:watch": "vitest watch",
    "test:timezone": "node ./scripts/runTimezoneTests.mjs",
    "test:timezone:docker": "docker build --target timezone-test -f Dockerfile.timezone-test .",
    "test:table": "tsx ./src/printCrossings.ts",
    "types": "mkdirp src/generated/typebox && ts2typebox --input src/model/index.ts --output src/generated/typebox/index.ts",
    "wait:electron-assets": "tsx ./src/app/waitForElectronAssets.ts"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@tjsr/eslint-config": "github:tjsr/eslint-config#main",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/date-fns": "^2.5.3",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/source-map-support": "^0.5.10",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "babel-loader": "^10.1.1",
    "chokidar": "^5.0.0",
    "css-loader": "^7.1.4",
    "electron": "^42.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^10.5.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "jsdom": "^29.1.1",
    "jsonlint-cli": "^1.0.1",
    "mkdirp": "^3.0.1",
    "node-loader": "^2.1.0",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "ts2typebox": "^1.6.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/material": "^9.1.1",
    "@mui/x-data-grid": "^9.5.0",
    "any-date-parser": "^2.2.3",
    "cli-table3": "^0.6.5",
    "cli-tableau": "^2.0.1",
    "colors": "^1.4.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "electron-context-menu": "^4.1.2",
    "electron-debug": "^4.1.0",
    "electron-timber": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "source-map-support": "^0.5.21",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=11.4.1"
  },
  "optionalDependencies": {
    "node-adodb": "^5.0.3"
  },
  "allowScripts": {
    "electron@37.1.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true
  },
  "overrides": {
    "tar": ">7.5.10",
    "yaml": ">1.10.2",
    "ws": ">8.20.0",
    "underscore": ">1.13.7",
    "tunnel-agent": ">=0.6.0",
    "trim-newlines": ">=3.0.1",
    "tmp": ">0.2.5",
    "node-fetch": ">=2.6.7",
    "minimist": ">0.2.3",
    "minimatch": ">3.1.3",
    "lodash": ">4.17.23",
    "@electron/asar": ">=4.2.0"
  }
}
