{
  "configurations": [

  {
    "name": "Launch via NPM",
    "request": "launch",
    "runtimeArgs": [
      "run-script",
      "debug"
    ],
    "runtimeExecutable": "npm",
    "skipFiles": [
      "<node_internals>/**"
    ],
    "type": "node"
  },
  {
    "name": "Debug printCrossings.ts",
    "type": "node",
    "request": "launch",
    "runtimeExecutable": "tsx",
    "program": "${workspaceFolder}/src/printCrossings.ts",
    "skipFiles": [
      "<node_internals>/**"
    ],
    "console": "integratedTerminal",
    "preLaunchTask": "debug: clear terminal and runtime caches"
  },
  {
    "name": "Electron Main",
    "type": "node",
    "request": "launch",
    "runtimeExecutable": "npm",
    "runtimeArgs": ["run", "serve"],
    "env": {
      "NODE_ENV": "development",
      "ELECTRON_ENABLE_LOGGING": "1"
    },
    "sourceMaps": true,
    "outFiles": [
      "${workspaceFolder}/.webpack/**/*.js"
    ],
    "sourceMapPathOverrides": {
      "webpack://racesweet/./*": "${workspaceFolder}/*",
      "webpack:///./*": "${workspaceFolder}/*",
      "webpack:///./~/*": "${workspaceFolder}/node_modules/*"
    },
    "console": "integratedTerminal",
    "autoAttachChildProcesses": true,
    "skipFiles": [
      "<node_internals>/**"
    ]
  },
  {
    "name": "Electron Renderer",
    "request": "launch",
    "type": "chrome",
    "preLaunchTask": "electron: serve",
    "url": "${env:DEBUG_RENDERER_URL:http://localhost:3488}",
    "webRoot": "${workspaceFolder}/src",
    "sourceMapPathOverrides": {
      "webpack://*/*": "*"
    }
  },
  {
    "name": "Electron Renderer Attach",
    "request": "launch",
    "type": "chrome",
    "preLaunchTask": "electron: wait for assets",
    "url": "${env:DEBUG_RENDERER_URL:http://localhost:3488}",
    "webRoot": "${workspaceFolder}/src",
    "sourceMapPathOverrides": {
      "webpack://*/*": "*"
    },
    "presentation": {
      "hidden": true
    }
  },
  {
    "type": "node",
    "request": "launch",
    "name": "Debug Vitest Tests",
    "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
    "args": ["run", "--threads", "false", "--no-cache"],
    "autoAttachChildProcesses": true,
    "preLaunchTask": "vitest: clear cache",
    "smartStep": true,
    "skipFiles": ["<node_internals>/**"],
    "console": "integratedTerminal"
  },
  {
    "name": "Debug pmtk.ts",
    "type": "node",
    "request": "launch",
    "runtimeExecutable": "tsx",
    "program": "${workspaceFolder}/src/pmtk.ts",
    "skipFiles": [
      "<node_internals>/**"
    ],
    "console": "integratedTerminal",
    "preLaunchTask": "debug: clear terminal and runtime caches"
  },
  {
    "type": "node",
    "request": "launch",
    "name": "Debug apicalTest",
    "runtimeExecutable": "tsx",
    "program": "${workspaceFolder}/src/utils/apical/apicalTest.mts",
    "skipFiles": [
      "<node_internals>/**"
    ],
    "console": "integratedTerminal",
    "preLaunchTask": "debug: clear terminal and runtime caches"
  },
  {
    "type": "node",
    "request": "launch",
    "name": "Debug apicalTest [limit]",
    "runtimeExecutable": "tsx",
    "program": "${workspaceFolder}/src/utils/apical/apicalTest.mts",
    "skipFiles": [
      "<node_internals>/**"
    ],
    "args": ["--limit=1", "--forceRefresh"],
    "console": "integratedTerminal",
    "preLaunchTask": "debug: clear terminal and runtime caches"
  }
  ],
  "compounds": [
    {
      "name": "Electron All",
      "configurations": ["Electron Main", "Electron Renderer Attach"],
      "stopAll": true
    }
  ]
}
