// filepath: /h:/dev/racesweet/.vscode/tasks.json
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tsc: build",
      "type": "shell",
      "command": "npx tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "detail": "Compiles TypeScript files"
    },
    {
      "label": "tsc: watch",
      "type": "shell",
      "command": "npx tsc --watch --preserveWatchOutput",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "detail": "Watches TypeScript files for changes"
    },
    {
      "label": "electron: serve",
      "type": "shell",
      "command": "npm run serve",
      "isBackground": true,
      "problemMatcher": {
        "owner": "electron-forge",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Webpack Output Available|Launching Application|Compiled successfully"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "detail": "Starts Electron Forge so main, preload, renderer assets, and the dev asset server are available"
    },
    {
      "label": "electron: wait for assets",
      "type": "shell",
      "command": "npm run wait:electron-assets",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "detail": "Waits until the Electron Forge webpack dev asset server is responding"
    },
    {
      "label": "clear-terminal",
      "type": "shell",
      "command": "cls",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "vitest: clear cache",
      "type": "shell",
      "command": "npx vitest --clearCache && npx rimraf node_modules/.vite .vitest",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "detail": "Clears Vitest and Vite transform caches before debug runs so stack traces map to current TypeScript files"
    },
    {
      "label": "runtime: clear caches",
      "type": "shell",
      "command": "node ./scripts/clearRuntimeCaches.mjs",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "detail": "Clears TSX/Vite/Vitest runtime caches and stale compiled sidecars before TypeScript debug runs"
    },
    {
      "label": "debug: clear terminal and runtime caches",
      "dependsOrder": "sequence",
      "dependsOn": [
        "clear-terminal",
        "runtime: clear caches"
      ],
      "problemMatcher": []
    }
  ]
}
