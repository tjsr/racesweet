{
  "ts.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "watchFilePolling": 1000,
    "watchDirectoryPolling": 1000,
    "watchFileTimeout": 1000,
    "watchDirectoryTimeout": 1000,
    "log": "off"
  },
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsdk.preferences.importModuleSpecifierEnding": "ts",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true
  },
  "vitest.rootConfig": "vitest.config.mts",
  "vitest.cliArguments": "--silent --no-cache",
  "vitest.logLevel": "verbose",
  "vitest.configSearchPatternExclude": "{.git/**,**/node_modules/**,**/.*/**,**/*.d.ts}",
  // "vitest.filesWatcherInclude": "**/*.{ts,tsx,mts},src/*.{js,jsx,mjs,cjs,json}",
  "search.useParentIgnoreFiles": false,
  "terminal.integrated.scrollback": 100000,
  "chat.tools.terminal.autoApprove": {
    "npm --prefix h:\\dev\\racesweet": true,
    "npx tsc": true,
    "rs": true
  },
  "cognitiveServices": {
    "endpoint": "http://localhost:11434",
    "key": ""
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  }
}
